# Better Auth Configuration
# A random secret key for auth (can be generated using `openssl rand -hex 32`)
BETTER_AUTH_SECRET=your_better_auth_secret_here
# The base URL of the Better Auth server (e.g., http://localhost:3000 for dev)
BETTER_AUTH_BASE_URL=http://localhost:3000
# The public URL of the application
NEXT_PUBLIC_URL=http://localhost:3000

# Database Configuration
# PostgreSQL connection string (e.g., Supabase pooler or local Postgres instance)
DATABASE_URL="postgresql://username:password@host:port/database"

# SMTP / Mailer Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your_smtp_password_here

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE=your_twilio_phone_number_here

# Ngrok / Public Base URL (Required for webhooks/IVR callback)
BASE_URL=https://your-ngrok-subdomain.ngrok-free.dev

# Data.gov API
DATA_GOV_API_KEY=your_data_gov_api_key_here

# Upstash Redis
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_rest_token_here"

# Facebook Configuration
FACEBOOK_CLIENT_ID=your_facebook_client_id_here
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret_here
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# AI & Speech APIs
MURF_API_KEY=your_murf_api_key_here
GROQ_API_KEY=your_groq_api_key_here
SARVAM_API_KEY=your_sarvam_api_key_here
SMITHERY_API_KEY=your_smithery_api_key_here

# Supabase Access
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here

# Cloudflare R2 Storage (or S3-compatible object storage)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your_bucket_name
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev
